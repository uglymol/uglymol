{
  "name": "gemmimol",
  "version": "0.7.2",
  "description": "Gemmi-backed macromolecular viewer for crystallographers",
  "keywords": [
    "crystallography",
    "biochemistry",
    "webgl",
    "coot",
    "protein",
    "structure"
  ],
  "homepage": "https://uglymol.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/uglymol/uglymol.git"
  },
  "license": "MIT",
  "main": "gemmimol.js",
  "module": "src/all.ts",
  "jsnext:main": "src/all.ts",
  "files": [
    "gemmimol.js",
    "gemmimol.js.map",
    "gemmimol.min.js",
    "src"
  ],
  "scripts": {
    "build": "npm test && npm run uglify",
    "bundle": "rollup -c",
    "coverage": "rollup -c --sourcemap && jest --testMatch='**/test/*.js' --coverage --collectCoverageFrom='gemmimol.js'",
    "download-data": "node perf/util.js download-data",
    "lint": "eslint src test perf || exit 0",
    "prepublish": "npm run build",
    "serve": "serve -l 7890",
    "start": "npm run watch & npm run serve",
    "test": "npm run lint && tsc --noEmit src/*.ts && rollup -c && jest --testMatch='**/test/*.js'",
    "uglify": "uglifyjs gemmimol.js -o gemmimol.min.js --compress --mangle",
    "version": "npm run build && git add -A gemmimol.js",
    "watch": "rollup -c --watch"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-buble": "^1.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@types/node": "^25.4.0",
    "benchmark": "^2.1.0",
    "eslint": "^10.0.3",
    "jest": "^29.7.0",
    "rollup": "^4.59.0",
    "serve": "^14.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "uglify-js": "^3.19.3"
  }
}
